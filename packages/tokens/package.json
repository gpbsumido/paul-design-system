{
  "name": "@paul-portfolio/tokens",
  "version": "0.1.5",
  "description": "Design tokens for the Paul Design System",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gpbsumido/paul-design-system.git",
    "directory": "packages/tokens"
  },
  "main": "./build/index.js",
  "module": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/index.js",
      "require": "./build/index.cjs",
      "types": "./build/index.d.ts"
    },
    "./tokens.css": "./build/tokens.css",
    "./tokens.scss": "./build/tokens.scss",
    "./tokens.json": "./build/tokens.json"
  },
  "files": ["build/"],
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf build",
    "test": "vitest run"
  }
}
